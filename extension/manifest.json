{
  "manifest_version": 3,
  "name": "CRM Ramon Pacheco Advocacia",
  "version": "4.0.0",
  "description": "Chat + Funil Kanban integrado ao WhatsApp Web",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CRM Advocacia"
  }
}
